{
  "name": "pi-deep-research",
  "version": "0.30.3",
  "description": "Autonomous deep web research extension for Pi coding agent",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/timaliev/pi-deep-research"
  },
  "scripts": {
    "pretest": "npx biome lint extension/ tests/ && npx biome format extension/ tests/",
    "test": "cd extension && npx tsx --test ../tests/*.test.ts",
    "format": "npx biome format --write extension/ tests/",
    "format:check": "npx biome format extension/ tests/",
    "lint": "npx biome lint extension/ tests/",
    "lint:fix": "npx biome lint --write extension/ tests/",
    "check": "npx biome check extension/ tests/",
    "check:fix": "npx biome check --write extension/ tests/"
  },
  "pi": {
    "extensions": [
      "./extension/index.ts"
    ],
    "skills": [
      "./skill"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3"
  }
}
