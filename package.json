{
  "name": "pi-deep-research",
  "version": "0.24.0",
  "description": "Autonomous deep web research extension for Pi coding agent",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/timaliev/pi-deep-research"
  },
  "scripts": {
    "pretest": "biome lint extension/ tests/",
    "test": "npx tsx --test tests/*.test.ts",
    "format": "biome format --write extension/ tests/",
    "format:check": "biome format extension/ tests/",
    "lint": "biome lint extension/ tests/",
    "lint:fix": "biome lint --write extension/ tests/",
    "check": "biome check extension/ tests/",
    "check:fix": "biome check --write extension/ tests/"
  },
  "pi": {
    "extensions": [
      "./extension/index.ts"
    ],
    "skills": [
      "./skill"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3"
  }
}
